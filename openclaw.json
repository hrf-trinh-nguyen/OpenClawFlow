{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": "openai/gpt-5.1",
      "compaction": {
        "mode": "safeguard"
      },
      "elevatedDefault": "full"
    }
  },
  "tools": {
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "slack": [
          "U091B2492SX",
          "U088DMSLFC7",
          "U08FLNSDQ78"
        ]
      }
    },
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "cron": {
    "enabled": false,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 1,
    "sessionRetention": "24h",
    "runLog": {
      "maxBytes": "2mb",
      "keepLines": 2000
    }
  },
  "channels": {
    "slack": {
      "mode": "socket",
      "webhookPath": "/slack/events",
      "enabled": true,
      "botToken": "${SLACK_BOT_TOKEN}",
      "appToken": "${SLACK_APP_TOKEN}",
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "U091B2492SX",
        "U088DMSLFC7",
        "U08FLNSDQ78"
      ],
      "channels": {
        "C0A720WG11N": {
          "allow": true
        },
        "*": {
          "requireMention": true
        }
      },
      "nativeStreaming": true,
      "streaming": "partial",
      "commands": {
        "native": true,
        "nativeSkills": true
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "skills": {
    "entries": {
      "apollo": {
        "enabled": true,
        "env": {
          "APOLLO_API_KEY": "${APOLLO_API_KEY}",
          "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR}"
        }
      },
      "bouncer": {
        "enabled": true,
        "env": {
          "BOUNCER_API_KEY": "${BOUNCER_API_KEY}",
          "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR}"
        }
      },
      "instantly": {
        "enabled": true,
        "env": {
          "INSTANTLY_API_KEY": "${INSTANTLY_API_KEY}",
          "INSTANTLY_CAMPAIGN_ID": "${INSTANTLY_CAMPAIGN_ID}",
          "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR}"
        }
      },
      "report-build": {
        "enabled": true,
        "env": {
          "SUPABASE_DB_URL": "${SUPABASE_DB_URL}",
          "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR}"
        }
      },
      "slack-notify": {
        "enabled": true,
        "env": {
          "SLACK_CHANNEL": "${SLACK_REPORT_CHANNEL}",
          "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR}"
        }
      },
      "lead-stats": {
        "enabled": true,
        "env": {
          "SUPABASE_DB_URL": "${SUPABASE_DB_URL}",
          "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR}"
        }
      },
      "lead-move": {
        "enabled": true,
        "env": {
          "SUPABASE_DB_URL": "${SUPABASE_DB_URL}",
          "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR}"
        }
      },
      "lead-delete": {
        "enabled": true,
        "env": {
          "SUPABASE_DB_URL": "${SUPABASE_DB_URL}",
          "OPENCLAW_STATE_DIR": "${OPENCLAW_STATE_DIR}"
        }
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.2",
    "lastTouchedAt": "2026-03-03T09:08:43.014Z"
  }
}