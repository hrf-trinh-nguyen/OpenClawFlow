# ==============================================================
# OpenClaw Outbound Automation – Environment Variables
# Copy to ~/.openclaw/.env or export in shell before running gateway
# ==============================================================

# ── LLM (agent and reply classification) ─────────────────────
OPENAI_API_KEY=

# ── Slack (channels + daily report) ───────────────────────────
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_REPORT_CHANNEL=C1234567890

# ── Apollo (list building) ───────────────────────────────────
APOLLO_API_KEY=

# ── Bouncer (email validation) ───────────────────────────────
BOUNCER_API_KEY=

# ── Instantly (load leads + capture replies) ──────────────────
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=

