# ── OpenClaw Gateway ──────────────────────────────────────────
# Copy this file to:
# - Local dev: /home/os/openclaw-mvp/.env
# - VPS:       /home/deploy/openclaw-mvp/.env
OPENCLAW_GATEWAY_TOKEN=your-random-hex-token-here

# ── State (shared across workflow steps; required for build-list etc.) ─
OPENCLAW_STATE_DIR=/path/to/your/openclaw-mvp/state

# ── LLM (agent + reply classification) ────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Slack (channels.slack + daily-report) ─────────────────────
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_REPORT_CHANNEL=C01234ABCDE
APOLLO_API_KEY=your-apollo-api-key
APOLLO_BATCH_SIZE=1
BOUNCER_API_KEY=your-bouncer-api-key
LOAD_LIMIT=200
INSTANTLY_LOAD_DAILY_CAP=600
BOUNCER_DAILY_CAP=600
BOUNCER_BATCH_SIZE=100
BOUNCER_PER_RUN_MAX=100

# ── instantly-load + instantly-fetch ─────────────────────────
INSTANTLY_API_KEY=your-instantly-api-key-base64
INSTANTLY_CAMPAIGN_ID=your-campaign-uuid
SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
