# OpenClaw pipeline — Pacific Time (America/Los_Angeles)
# Install: ./scripts/install-cron.sh  (from repo root, as deploy user)
#
# Build list: 3:00, 4:00, 5:00 AM PT
# Load campaign: 5:15, 5:45 AM PT

TZ=America/Los_Angeles
OPENCLAW_REPO=/home/deploy/openclaw-mvp

0 3,4,5 * * * OPENCLAW_HOME=$OPENCLAW_REPO $OPENCLAW_REPO/scripts/run-build-list.sh >> $OPENCLAW_REPO/logs/build-list.log 2>&1
15,45 5 * * * OPENCLAW_HOME=$OPENCLAW_REPO $OPENCLAW_REPO/scripts/run-load-campaign.sh >> $OPENCLAW_REPO/logs/load-campaign.log 2>&1
