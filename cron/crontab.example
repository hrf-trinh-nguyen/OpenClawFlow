# OpenClaw pipeline — Schedule in UTC (server timezone)
# Install: ./scripts/install-cron.sh  (from repo root, as deploy user)
#
# ┌─────────────────────────────────────────────────────────────────────────────
# │ IMPORTANT: Cron uses SERVER TIMEZONE (UTC). TZ variable is NOT supported
# │ by most Linux cron daemons. All times below are in UTC.
# │
# │ PT ↔ UTC conversion (PDT = UTC-7, PST = UTC-8):
# │   5 AM PT (PDT) = 12:00 UTC    |    5 AM PT (PST) = 13:00 UTC
# │  10 AM PT (PDT) = 17:00 UTC    |   10 AM PT (PST) = 18:00 UTC
# │  10 PM PT (PDT) = 05:00 UTC+1  |   10 PM PT (PST) = 06:00 UTC+1
# │
# │ Current schedule (PDT, Mar-Nov):
# │ ├─────────────────────────────────────────────────────────────────────────
# │ │ Bouncer:          5, 6, 7, 8 AM PT  = 12, 13, 14, 15 UTC
# │ │ Load campaign:    5:30, 6:30, 7:30, 8:30 AM PT = 12:30, 13:30, 14:30, 15:30 UTC
# │ │ Process replies:  10 AM – 9 PM PT = 17:00 – 04:00 UTC (spans midnight)
# │ │ Daily report:     10 PM PT = 05:00 UTC (next day)
# └─────────────────────────────────────────────────────────────────────────────

OPENCLAW_REPO=/home/deploy/openclaw-mvp

# ── Bouncer Verify: 5, 6, 7, 8 AM PT = 12, 13, 14, 15 UTC ─────────────────────
# Runs 4x/morning to incrementally verify leads. Daily cap: 300.
0 12,13,14,15 * * * OPENCLAW_HOME=$OPENCLAW_REPO $OPENCLAW_REPO/scripts/run-build-list.sh >> $OPENCLAW_REPO/logs/build-list.log 2>&1

# ── Load Campaign: 5:30, 6:30, 7:30, 8:30 AM PT = 12:30, 13:30, 14:30, 15:30 UTC
# Runs 4x/morning to push verified leads. Daily cap: 250.
30 12,13,14,15 * * * OPENCLAW_HOME=$OPENCLAW_REPO $OPENCLAW_REPO/scripts/run-load-campaign.sh >> $OPENCLAW_REPO/logs/load-campaign.log 2>&1

# ── Process Replies: 10 AM – 9 PM PT = 17-23,0-4 UTC (spans midnight) ─────────
# Hourly fetch & classify replies during business hours PT.
0 17,18,19,20,21,22,23,0,1,2,3,4 * * * OPENCLAW_HOME=$OPENCLAW_REPO $OPENCLAW_REPO/scripts/run-process-replies.sh >> $OPENCLAW_REPO/logs/process-replies.log 2>&1

# ── Daily Report: 10 PM PT = 05:00 UTC (next day) ─────────────────────────────
0 5 * * * OPENCLAW_HOME=$OPENCLAW_REPO $OPENCLAW_REPO/scripts/run-daily-report.sh >> $OPENCLAW_REPO/logs/daily-report.log 2>&1
